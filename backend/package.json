{
  "name": "dentalcare-backend",
  "version": "1.0.0",
  "description": "Backend API para a clínica DentalCare",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "npx prisma migrate dev --name init",
    "generate": "npx prisma generate",
    "seed": "node prisma/seed.js",
    "setup": "npx prisma migrate dev --name init && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "prisma": "^5.22.0"
  }
}
