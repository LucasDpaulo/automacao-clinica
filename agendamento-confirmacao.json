    {
      "parameters": {
        "operation": "executeQuery",
        "query": "DROP TABLE IF EXISTS consultas;\nDROP TABLE IF EXISTS medicos;\nDROP TABLE IF EXISTS especialidades;\n\nCREATE TABLE especialidades (\n  id SERIAL PRIMARY KEY,\n  nome VARCHAR(100)\n);\n\nCREATE TABLE medicos (\n  id SERIAL PRIMARY KEY,\n  nome VARCHAR(100),\n  especialidade_id INT REFERENCES especialidades(id)\n);\n\nCREATE TABLE consultas (\n  id SERIAL PRIMARY KEY,\n  medico_id INT REFERENCES medicos(id),\n  paciente_nome VARCHAR(100),\n  telefone VARCHAR(30),\n  data DATE,\n  hora TIME,\n  status VARCHAR(20) DEFAULT 'disponivel'\n);\n\n-- ESPECIALIDADES\nINSERT INTO especialidades (nome) VALUES\n('Clínico Geral'),\n('Periodontista'),\n('Endodontista'),\n('Ortodontista'),\n('Implantodontista');\n\n-- MÉDICOS\nINSERT INTO medicos (nome, especialidade_id) VALUES\n('Dr. João Silva', 1),\n('Dra. Maria Souza', 2),\n('Dr. Carlos Lima', 3),\n('Dra. Ana Costa', 4),\n('Dr. Pedro Rocha', 5);\n\n-- HORÁRIOS DISPONÍVEIS\nINSERT INTO consultas (medico_id, data, hora, status) VALUES\n(1, CURRENT_DATE + INTERVAL '1 day', '09:00', 'disponivel'),\n(1, CURRENT_DATE + INTERVAL '1 day', '10:00', 'disponivel'),\n(2, CURRENT_DATE + INTERVAL '1 day', '11:00', 'disponivel'),\n(3, CURRENT_DATE + INTERVAL '2 day', '14:00', 'disponivel'),\n(4, CURRENT_DATE + INTERVAL '2 day', '15:00', 'disponivel'),\n(5, CURRENT_DATE + INTERVAL '3 day', '16:00', 'disponivel');\n\n-- HORÁRIOS JÁ AGENDADOS\nINSERT INTO consultas (medico_id, paciente_nome, telefone, data, hora, status) VALUES\n(1, 'Carlos Teste', '55999999999', CURRENT_DATE, '09:00', 'agendado'),\n(2, 'Ana Teste', '55888888888', CURRENT_DATE, '10:00', 'agendado');",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        1312,
        560
      ],
      "id": "c9df4360-bb7b-482e-85a1-16c887655466",
      "name": "Execute a SQL query",
      "credentials": {
