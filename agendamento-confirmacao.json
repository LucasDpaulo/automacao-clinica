    {
      "parameters": {
        "descriptionType": "manual",
        "toolDescription": "Lista as especialidades e os dentistas da clínica. O assistente deve responder em linguagem natural e amigável, sem mencionar ferramenta ou detalhes técnicos.",
        "operation": "executeQuery",
        "query": "SELECT\n  e.nome AS especialidade,\n  m.nome AS medico\nFROM especialidades e\nJOIN medicos m ON m.especialidade_id = e.id\nORDER BY e.nome, m.nome;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgresTool",
      "typeVersion": 2.6,
      "position": [
        1328,
        384
      ],
      "id": "cd608fbd-111c-4cba-81e9-e36bbd051180",
      "name": "ver_especialidades",
      "credentials": {
        "postgres": {
          "id": "q9KQF3UbVNCY6dle",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "descriptionType": "manual",
        "toolDescription": "Busca horários disponíveis reais no banco. Retorna uma lista ordenada com id_horario, data, hora, médico e especialidade. O assistente deve mostrar isso ao paciente como Opção 1, Opção 2, Opção 3, sem exibir o id_horario.",
        "operation": "executeQuery",
        "query": "SELECT\n  c.id AS id_horario,\n  TO_CHAR(c.data, 'YYYY-MM-DD') AS data,\n  TO_CHAR(c.hora, 'HH24:MI') AS hora,\n  m.nome AS medico,\n  e.nome AS especialidade\nFROM consultas c\nJOIN medicos m ON c.medico_id = m.id\nJOIN especialidades e ON m.especialidade_id = e.id\nWHERE c.status = 'disponivel'\nORDER BY c.data, c.hora\nLIMIT 20;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgresTool",
      "typeVersion": 2.6,
      "position": [
        1152,
        384
      ],
      "id": "27f68dda-646b-4726-b280-43894d2e76b6",
      "name": "consultar_agenda",
      "credentials": {
        "postgres": {
          "id": "q9KQF3UbVNCY6dle",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "descriptionType": "manual",
        "toolDescription": "Confirma um agendamento usando internamente o id_horario correspondente à opção escolhida pelo paciente. Nunca mostrar o id_horario ao paciente.",
        "operation": "executeQuery",
        "query": "UPDATE consultas\nSET\n  paciente_nome = '{{ $('Dados').item.json.nome }}',\n  telefone = '{{ $('Dados').item.json.telefone }}',\n  status = 'agendado'\nWHERE id = {{ $fromAI('id_horario', 'ID do horário disponível escolhido pelo usuário', 'number') }}\n  AND status = 'disponivel'\nRETURNING\n  id AS id_horario,\n  TO_CHAR(data, 'YYYY-MM-DD') AS data,\n  TO_CHAR(hora, 'HH24:MI') AS hora,\n  paciente_nome,\n  telefone,\n  status;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgresTool",
      "typeVersion": 2.6,
      "position": [
        1488,
        384
      ],
      "id": "23f1e92e-e0fa-4119-aefb-6273cf1d4811",
      "name": "criar_agendamento",
      "credentials": {
        "postgres": {
          "id": "q9KQF3UbVNCY6dle",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "descriptionType": "manual",
        "toolDescription": "Cancela o próximo agendamento do paciente atual com base no telefone. O assistente deve informar o cancelamento de forma humana e sem detalhes técnicos.",
        "operation": "executeQuery",
        "query": "WITH alvo AS (\n  SELECT id\n  FROM consultas\n  WHERE telefone = '{{ $('Dados').item.json.telefone }}'\n    AND status = 'agendado'\n  ORDER BY data, hora\n  LIMIT 1\n)\nUPDATE consultas\nSET\n  paciente_nome = NULL,\n  telefone = NULL,\n  status = 'disponivel'\nWHERE id IN (SELECT id FROM alvo)\nRETURNING\n  id AS id_horario,\n  TO_CHAR(data, 'YYYY-MM-DD') AS data,\n  TO_CHAR(hora, 'HH24:MI') AS hora,\n  status;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgresTool",
      "typeVersion": 2.6,
      "position": [
        1152,
        560
      ],
      "id": "beae7e4e-a7fa-4f52-a4d6-b78efffa67e7",
      "name": "cancelar_agendamento",
      "credentials": {
        "postgres": {
          "id": "q9KQF3UbVNCY6dle",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "descriptionType": "manual",
        "toolDescription": "Reagenda a consulta do paciente para um novo horário escolhido. O assistente deve mostrar horários em formato de opções e nunca expor ids internos.",
        "operation": "executeQuery",
        "query": "WITH atual AS (\n  SELECT id\n  FROM consultas\n  WHERE telefone = '{{ $('Dados').item.json.telefone }}'\n    AND status = 'agendado'\n  ORDER BY data, hora\n  LIMIT 1\n),\nlibera AS (\n  UPDATE consultas\n  SET\n    paciente_nome = NULL,\n    telefone = NULL,\n    status = 'disponivel'\n  WHERE id IN (SELECT id FROM atual)\n  RETURNING id\n),\nnovo AS (\n  UPDATE consultas\n  SET\n    paciente_nome = '{{ $('Dados').item.json.nome }}',\n    telefone = '{{ $('Dados').item.json.telefone }}',\n    status = 'agendado'\n  WHERE id = {{ $fromAI('id_horario_novo', 'ID do novo horário disponível escolhido pelo usuário', 'number') }}\n    AND status = 'disponivel'\n  RETURNING id, data, hora, status\n)\nSELECT\n  id AS id_horario,\n  TO_CHAR(data, 'YYYY-MM-DD') AS data,\n  TO_CHAR(hora, 'HH24:MI') AS hora,\n  status\nFROM novo;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgresTool",
      "typeVersion": 2.6,
      "position": [
        1504,
        560
      ],
      "id": "0dc8d907-0622-43bf-9783-7f1bf4f978f4",
      "name": "reagendar_agendament",
      "credentials": {
        "postgres": {
          "id": "q9KQF3UbVNCY6dle",
          "name": "Postgres account"
        }
      }
    },
